# Hoist packages necesarios para que Metro (React Native) resuelva correctamente los módulos.
# Sin esto, pnpm strict mode causa "Cannot find module" para dependencias transitivas
# que babel/metro inyectan en los bundles.
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@babel/runtime/*
public-hoist-pattern[]=react-native-css-interop
public-hoist-pattern[]=react-native-css-interop/*
